<!-- breadcrumb part -->
<section class="breadcrumb_part blog_grid_bg">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 ">
                <div class="breadcrumb_iner">
                    <h2>مقالات مشاوره ای</h2>
                    <div class="breadcrumb_iner_link">
                        <a href="/">خانه</a>
                        <i class="arrow_carrot-left"></i>
                        <span>مقالات مشاوره ای</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- breadcrumb part end -->

<!-- blog grid part here -->
<section class="blog_posts page_section_padding">
    <div class="container">
        <!-- Posts Grid -->
        <div class="row justify-content-center">
            <% if (posts && posts.length > 0) { %>
                <% posts.forEach((post, index) => { %>
                    <div data-aos="fade-up" data-aos-duration="<%= 1200 + (index * 200) %>" class="col-xl-6 col-lg-6 col-md-12 col-sm-12">
                        <div class="blog_post_list">
                            <div class="single_page_blog_post">
                                <img src="<%= post.image %>" alt="#" class="img-fluid">
                                <div class="single_blog_content">
                                    <div class="post_author">
                                        <p><%= post.date %><i class="icon_clock_alt"></i></p>
                                        <p><%= post.author %><i class="icon_profile"></i></p>
                                    </div>
                                    <h2> <a href="/blog/post/<%= post.id %>"><%= post.title %></a> </h2>
                                    <p><%= post.excerpt ? post.excerpt.substring(0, 150) : '' %>...</p>
                                    <a href="/blog/post/<%= post.id %>" class="read_more_btn">بیشتر <i class="arrow_left"></i> </a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-12 text-center">
                    <p style="padding: 50px 0; font-size: 18px; color: #666;">هیچ مقاله‌ای یافت نشد</p>
                </div>
            <% } %>
        </div>
        
        <!-- ✅ Pagination -->
        <% if (totalPages > 1) { %>
            <div data-aos="fade-up" data-aos-duration="2400" class="page_pageination justify-content-start">
                <!-- Previous Arrow -->
                <% if (currentPage > 1) { %>
                    <a href="?page=<%= currentPage - 1 %>">
                        <i class="arrow_carrot-left"></i>
                    </a>
                <% } else { %>
                    <a href="#" class="disabled">
                        <i class="arrow_carrot-left"></i>
                    </a>
                <% } %>
                
                <!-- Page Numbers -->
                <% for (let i = 1; i <= totalPages; i++) { %>
                    <a href="?page=<%= i %>" class="<%= i === currentPage ? 'current' : '' %>">
                        <%= i %>
                    </a>
                <% } %>
                
                <!-- Next Arrow -->
                <% if (currentPage < totalPages) { %>
                    <a href="?page=<%= currentPage + 1 %>">
                        <i class="arrow_carrot-right"></i>
                    </a>
                <% } else { %>
                    <a href="#" class="disabled">
                        <i class="arrow_carrot-right"></i>
                    </a>
                <% } %>
            </div>
        <% } %>
    </div>
</section>
<!-- blog grid part end -->

<!-- cta part here -->
<section class="cta_part section_padding">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
