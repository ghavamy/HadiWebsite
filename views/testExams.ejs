                                        </span>
                                    </div>
                                </div>
                                <div class="lesson-actions">
                                    <% if (lesson.video) { %>
                                        <a href="/course/<%= pdfCourse.slug %>/lesson/<%= lesson.session %>" class="btn-watch">
                                            <i class="fas fa-play"></i> تماشا
                                        </a>
                                    <% } %>
                                    <% if (lesson.pdf) { %>
                                        <a href="/download/pdf/<%= lesson.pdf %>" class="btn-download-pdf" download>
                                            <i class="fas fa-file-pdf"></i> دانلود PDF
                                            <span class="download-size">2.4 MB</span>
                                        </a>
                                    <% } %>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</div>

