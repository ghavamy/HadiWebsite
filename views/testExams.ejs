<div class="pdf-course-container">
    <!-- Header -->
    <div class="pdf-course-header">
        <div class="header-content">
            <h2><i class="fas fa-graduation-cap"></i> آزمون های آزمایشی</h2>
            <p>دانلود فایل‌های PDF آزمون مختلف</p>
        </div>
        <div class="header-stats">
            <span class="stat-badge">
                <i class="fas fa-file-pdf"></i> <%= fileCount || 0 %> فایل
            </span>
            <span class="stat-badge">
                <i class="fas fa-download"></i> قابل دانلود
            </span>
        </div>
    </div>

    <!-- Tabs -->
    <div class="pdf-tabs-modern">
        <% subjects.forEach((subject, index) => { %>
            <button class="tab-btn-modern <%= index === 0 ? 'active' : '' %>" data-tab="<%= subject %>">
                <i class="fas <%= examsData[subject].icon %>"></i>
                <span><%= examsData[subject].name %></span>
                <span class="tab-count">
                    <%= examsData[subject].sections.reduce((sum, s) => sum + s.lessons.length, 0) %>
                </span>
            </button>
        <% }) %>
    </div>

    <!-- Tab Content -->
    <div class="pdf-tab-content">
        <% subjects.forEach((subject, index) => { %>
            <div class="pdf-tab-panel <%= index === 0 ? 'active' : '' %>" id="panel-<%= subject %>">
                <% const subjectData = examsData[subject]; %>
                <% if (subjectData.sections && subjectData.sections.length > 0) { %>
                    <% subjectData.sections.forEach((section, sectionIndex) => { %>
                        <div class="pdf-section">
                            <div class="pdf-section-header" onclick="toggleSection(this)">
                                <div class="section-info">
                                    <span class="section-number"><%= sectionIndex + 1 %></span>
                                    <div>
                                        <h3><%= section.title %></h3>
                                        <p><%= section.description || 'آزمون' %></p>
                                    </div>
                                </div>
                                <div class="section-meta">
                                    <span class="lesson-count"><%= section.lessons.length %> آزمون</span>
                                    <i class="fas fa-chevron-down toggle-icon"></i>
                                </div>
                            </div>
                            <div class="pdf-section-body">
                                <% section.lessons.forEach((lesson, lessonIndex) => { %>
                                    <div class="pdf-lesson-item">
                                        <div class="lesson-info">
                                            <span class="lesson-number"><%= lessonIndex + 1 %></span>
                                            <div class="lesson-details">
                                                <h4><%= lesson.title %></h4>
                                                <span class="lesson-badge">
                                                    <i class="fas fa-calendar-alt"></i> سال <%= lesson.year %>
                                                </span>
                                            </div>
                                        </div>
                                        <div class="lesson-actions">
                                            <% if (lesson.pdf) { %>
                                                <a href="/download/pdf/<%= lesson.pdf %>" class="btn-download-pdf" download>
                                                    <i class="fas fa-file-pdf"></i> دانلود آزمون
                                                </a>
                                            <% } %>
                                            <% if (lesson.answer) { %>
                                                <a href="/download/pdf/<%= lesson.answer %>" class="btn-download-pdf" download>
                                                    <i class="fas fa-file-pdf"></i> دانلود پاسخ تشریحی
                                                </a>
                                            <% } %>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="pdf-empty-state">
                        <i class="fas fa-file-pdf"></i>
                        <h3>هیچ فایل PDFی یافت نشد</h3>
                        <p>هنوز فایل‌های PDF برای این بخش اضافه نشده است.</p>
                    </div>
                <% } %>
            </div>
        <% }) %>
    </div>
</div>